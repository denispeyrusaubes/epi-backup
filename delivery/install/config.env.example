# =============================================================================
# Configuration Velero + Kopia + MinIO
# Copier ce fichier en config.env et adapter les valeurs.
#
# Usage :
#   cp config.env.example config.env
#   vim config.env
# =============================================================================

# --- MinIO ---
# URL du serveur MinIO (obligatoire)
MINIO_URL="https://minio.example.com:9000"

# Nom du bucket S3 (doit exister dans MinIO)
MINIO_BUCKET="velero-pra"

# Region S3 (convention MinIO — utiliser "minio" sauf raison contraire)
MINIO_REGION="minio"

# --- Velero ---
# Namespace Kubernetes pour Velero
VELERO_NAMESPACE="velero"

# Version du chart Helm vmware-tanzu/velero
CHART_VERSION="11.4.0"

# Nom de la release Helm
HELM_RELEASE="velero"

